  <property name="styleSheet">
   <string notr="true">QDialog, QWidget {
    QWidget {
    background-color: #121212; /* negro suave */
}

/* QLabel */
QLabel {
    color: #EAEAEA;
    font-weight: bold;
    font-size: 28pt;
}

/* Botones */
QPushButton {
    background-color: #1F1F1F;
    color: #00D084;
    border: 2px solid #00D084;
    border-radius: 10px;
    padding: 8px 16px;
    font-weight: bold;
}

/* Hover botón */
QPushButton:hover {
    background-color: #00D084;
    color: #121212;
}

/* Click botón */
QPushButton:pressed {
    background-color: #009e63;
}

/* QLineEdit */
QLineEdit {
    background-color: #1E1E1E;
    color: #EAEAEA;
    border: 2px solid #2C2C2C;
    border-radius: 8px;
    padding: 6px;
    selection-background-color: #00D084;
    selection-color: #121212;
}

/* Focus */
QLineEdit:focus {
    border: 2px solid #00D084;
    background-color: #252525;
}

/* Hover */
QLineEdit:hover {
    border: 2px solid #3A3A3A;
}

/* Placeholder */
QLineEdit::placeholder {
    color: #888888;
}
}</string>
